[Unit]
Description=Conduit edge agent
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/conduit-node
EnvironmentFile=/etc/conduit-node.env
ExecStart=/usr/local/bin/bun /opt/conduit-node/src/index.ts
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
